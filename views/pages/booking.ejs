<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <title>Book Service | CarBarn</title>
</head>
<body class="bg-surface">
    <%- include('../partials/navbar') %>

    <main class="section">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="car-card p-4 p-md-5 text-center">
                        <p class="eyebrow mb-2">Book with confidence</p>
                        <h1 class="display-6 fw-semibold text-white mb-3">Schedule your next car service with ease.</h1>
                        <p class="text-secondary mb-4">
                            Welcome<% if (currentUser) { %>, <%= currentUser.fullname.split(' ')[0] %><% } %>. Choose CarBarn for reliable maintenance, careful inspections, and support that keeps your vehicle ready for every journey.
                        </p>
                        <div class="d-flex flex-wrap justify-content-center gap-3">
                            <a href="/services" class="btn btn-primary">View Services</a>
                            <a href="/about" class="btn btn-outline-light">Learn More About Us</a>
                        </div>
                        <div class="mt-4 booking-note">
                            <p class="mb-0">You are signed in and ready to continue with your service selection.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>
