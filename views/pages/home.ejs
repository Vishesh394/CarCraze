<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home | CarCraze</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>
    <%- include('../partials/header',{title: "Home" }) %>
        <div class="container-fluid bg-dark text-white text-center p-5">
            <h1 class="display-4">Welcome to CarCraze</h1>
            <p class="lead">Your one-stop destination for trusted CarCraze and maintenance.</p>
            <a href="/services" class="btn btn-warning btn-lg">Explore Our Services</a>
        </div>
        <div class="container mt-5">
            <h2 class="text-center mb-4">Popular Services</h2>
            <div class="row">
                <div class="col-md-4">
                    <div class="card p-3 shadow">
                        <h5>Car Wash</h5>
                        <p>Interior and exterior cleaning for a fresh finish.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card p-3 shadow">
                        <h5>Oil Change</h5>
                        <p>Clean, efficient oil replacement to protect engine performance.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card p-3 shadow">
                        <h5>Full Service</h5>
                        <p>Comprehensive inspection and servicing for complete peace of mind.</p>
                    </div>
                </div>
            </div>
        </div>
        <%- include('../partials/footer')%>
</body>

</html>
