                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-3 shadow">
                    <h5>Oil change</h5>
                    <p>Engine oil replacement</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-3 shadow">
                    <h5>Full Service</h5>
                    <p>Complete inspection & servicing</p>
                </div>
            </div>
        </div>
    </div>
    
