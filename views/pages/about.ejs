<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>About | CarCraze Service</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-surface">
  <%- include("../partials/navbar") %>

  <!-- Hero -->
  <header class="hero hero--about">
    <div class="hero-overlay"></div>
    <div class="container position-relative">
      <div class="row align-items-center">
        <div class="col-lg-7">
          <p class="eyebrow text-white text-uppercase mb-2">About CarCraze</p>
          <h1 class="display-4 fw-bold text-white mb-3">
            We help every car feel better, safer, and ready for the road.
          </h1>
          <p class="lead text-white-50 mb-4">
            Our team of technicians, detailers, and service advisors is committed to high-quality work and a smooth customer experience.
          </p>
          <div class="d-flex flex-wrap gap-3">
            <a class="btn btn-primary btn-lg" href="/booking">Book Your Service</a>
            <a class="btn btn-outline-light btn-lg" href="/services">Explore Services</a>
          </div>
        </div>
      </div>
    </div>
  </header>

  <main>
    <!-- Who we are -->
    <section class="section container">
      <div class="row g-4 align-items-center">
        <div class="col-lg-6">
          <p class="eyebrow">Who we are</p>
          <h2 class="display-6 fw-semibold mb-3">A modern car care team built on trust.</h2>
          <p class="text-secondary">
            CarCraze combines professional tools with friendly, dependable service. From regular maintenance to detailing and diagnostics, we make every visit clear, efficient, and reassuring.
          </p>
          <ul class="list-unstyled text-secondary mt-3">
            <li>• Quality parts and trusted service procedures</li>
            <li>• Clear updates with honest recommendations</li>
            <li>• Comfortable support from drop-off to pick-up</li>
          </ul>
        </div>
        <div class="col-lg-6">
          <div class="car-card p-0 overflow-hidden">
            <div class="car-photo car-photo-about"></div>
            <div class="car-card-body">
              <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">A workshop you can trust</h5>
                <span class="badge rounded-pill bg-primary-subtle text-primary">Professional tools</span>
              </div>
              <p class="small text-secondary mt-2 mb-0">Clean service bays, skilled technicians, and careful processes that treat every vehicle with respect.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="section container">
      <div class="section-heading">
        <p class="eyebrow">Our promise</p>
        <h2 class="display-6 fw-semibold mb-0">Service that feels professional from start to finish.</h2>
      </div>
      <div class="row g-4 mt-2">
        <div class="col-md-4">
          <div class="feature-tile">
            <span class="feature-icon bg-primary-subtle text-primary">🧠</span>
            <h5>Skilled technicians</h5>
            <p>Experienced professionals handle inspections, diagnostics, and repair work with care.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="feature-tile">
            <span class="feature-icon bg-success-subtle text-success">💬</span>
            <h5>Clear communication</h5>
            <p>Upfront estimates, honest updates, and no unexpected add-ons without your approval.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="feature-tile">
            <span class="feature-icon bg-warning-subtle text-warning">🌱</span>
            <h5>Responsible care</h5>
            <p>Thoughtful cleaning methods and responsible handling of materials help reduce waste.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="section container-fluid bg-dark text-white rounded-4 py-5 px-4 px-md-5 mb-5">
      <div class="row align-items-center g-4">
        <div class="col-lg-6">
          <p class="eyebrow text-uppercase text-primary mb-1">By the numbers</p>
          <h2 class="display-6 fw-semibold">Built on consistent customer trust.</h2>
          <p class="text-light">Drivers return to Car craze because we make service easier, clearer, and more dependable every time.</p>
        </div>
        <div class="col-lg-6">
          <div class="stats-grid">
            <div class="stat-tile">
              <span class="stat-number">2k+</span>
              <p class="mb-0">Services completed</p>
            </div>
            <div class="stat-tile">
              <span class="stat-number">4.6★</span>
              <p class="mb-0">Customer satisfaction</p>
            </div>
            <div class="stat-tile">
              <span class="stat-number">24 hr</span>
              <p class="mb-0">Average turnaround</p>
            </div>
            <div class="stat-tile">
              <span class="stat-number">9 mo</span>
              <p class="mb-0">Workmanship support</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>
</body>
</html>
