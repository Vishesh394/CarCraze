<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Booking Success | CarCraze</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="bg-surface">
    <%- include('../partials/navbar') %>

    <main class="section">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="car-card p-4 p-md-5 text-center">
                        <p class="eyebrow mb-2">Booking confirmed</p>
                        <h1 class="display-6 fw-semibold text-white mb-3">Your service request has been received.</h1>
                        <p class="text-secondary mb-4">
                            Thanks<% if (booking.customer) { %>, <%= booking.customer %><% } %>. Your booking for <strong><%= booking.service %></strong> has been confirmed successfully.
                        </p>

                        <% if (booking.id) { %>
                            <div class="mb-4">
                                <span class="badge rounded-pill bg-primary-subtle text-primary">Booking ID: <%= booking.id %></span>
                            </div>
                        <% } %>

                        <div class="row g-3 text-start mb-4">
                            <div class="col-md-6">
                                <div class="booking-note h-100">
                                    <strong>Service</strong>
                                    <p class="mb-0 mt-2"><%= booking.service %></p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="booking-note h-100">
                                    <strong>Preferred Date</strong>
                                    <p class="mb-0 mt-2"><%= booking.date || "To be confirmed" %></p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="booking-note h-100">
                                    <strong>Vehicle</strong>
                                    <p class="mb-0 mt-2"><%= booking.vehicle || "Not provided" %></p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="booking-note h-100">
                                    <strong>Phone</strong>
                                    <p class="mb-0 mt-2"><%= booking.phone || "Not provided" %></p>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap justify-content-center gap-3">
                            <a href="/services" class="btn btn-primary">Book Another Service</a>
                            <a href="/" class="btn btn-outline-light">Back to Home</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>
