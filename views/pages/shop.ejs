<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <title>Accessories | CarBarn</title>
</head>
<body class="bg-surface">
    <%- include('../partials/navbar') %>

    <main class="section">
        <div class="container">
            <div class="car-card p-4 p-md-5">
                <p class="eyebrow mb-2">Accessories and upgrades</p>
                <h1 class="display-6 fw-semibold text-white mb-3">Explore quality accessories for style, comfort, and performance.</h1>
                <p class="text-secondary mb-0">
                    Welcome<% if (currentUser) { %>, <%= currentUser.fullname.split(' ')[0] %><% } %>. Discover a growing collection of practical upgrades and premium add-ons designed to enhance every drive.
                </p>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>
