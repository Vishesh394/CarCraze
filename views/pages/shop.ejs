<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Accessories | Car craze</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="bg-surface">
    <%- include('../partials/navbar') %>

    <main class="section">
        <div class="container">
            <div class="shop-hero car-card p-4 p-md-5 mb-4">
                <div class="row align-items-center g-4">
                    <div class="col-lg-8">
                        <p class="eyebrow mb-2">Accessories and upgrades</p>
                        <h1 class="display-5 fw-semibold mb-3">Build a smarter, cleaner, more comfortable drive.</h1>
                        <p class="text-secondary mb-0">
                            Welcome<% if (currentUser) { %>, <%= currentUser.fullname.split(' ')[0] %><% } %>. Browse practical car accessories across Interior, Exterior, Electronics, and Maintenance.
                        </p>
                    </div>
                    <div class="col-lg-4">
                        <div class="cart-summary-card">
                            <button
                                class="cart-logo-button"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#accessoriesCart"
                                aria-expanded="false"
                                aria-controls="accessoriesCart"
                            >
                                <span class="cart-logo-icon">Cart</span>
                                <span>
                                    <span class="small text-secondary d-block">Your cart</span>
                                    <strong><span data-cart-count>0</span> item(s)</strong>
                                </span>
                            </button>
                            <div class="collapse mt-3" id="accessoriesCart">
                                <div class="cart-panel">
                                    <div data-cart-items>
                                        <p class="small mb-0">Your cart is empty. Add accessories to see them here.</p>
                                    </div>
                                    <div class="cart-total-row">
                                        <span>Total</span>
                                        <strong>Rs <span data-cart-total>0</span></strong>
                                    </div>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <button class="btn btn-outline-light btn-sm flex-fill" type="button" data-clear-cart>Clear Cart</button>
                                        <button class="btn btn-primary btn-sm flex-fill" type="button" data-cart-checkout>Checkout</button>
                                    </div>
                                    <p class="small mb-0 mt-2" data-cart-message></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <% if (typeof error !== "undefined" && error) { %>
                <div class="alert alert-danger" role="alert">
                    <%= error %>
                </div>
            <% } %>

            <section class="car-card p-4 mb-5">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
                    <div>
                        <p class="eyebrow mb-1">Find accessories</p>
                        <h2 class="h4 mb-0">Filter by category and budget</h2>
                    </div>
                    <a class="btn btn-outline-light btn-sm" href="/shop">Reset Filters</a>
                </div>

                <form action="/shop" method="GET" class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label for="category" class="form-label">Category</label>
                        <select id="category" name="category" class="form-select">
                            <option value="">All Categories</option>
                            <% categories.forEach(item => { %>
                                <option value="<%= item %>" <%= filters.category === item ? "selected" : "" %>><%= item %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="minPrice" class="form-label">Min Price</label>
                        <input id="minPrice" name="minPrice" type="number" min="0" class="form-control" placeholder="Ex. 500" value="<%= filters.minPrice %>">
                    </div>
                    <div class="col-md-3">
                        <label for="maxPrice" class="form-label">Max Price</label>
                        <input id="maxPrice" name="maxPrice" type="number" min="0" class="form-control" placeholder="Ex. 3000" value="<%= filters.maxPrice %>">
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">Apply</button>
                    </div>
                </form>
            </section>

            <% if (recommendedAccessories && recommendedAccessories.length) { %>
                <section class="mb-5">
                    <div class="section-heading mb-3">
                        <p class="eyebrow">Recommended for your car</p>
                        <h2 class="display-6 fw-semibold mb-0">Smart picks for safety, comfort, and daily care.</h2>
                    </div>
                    <div class="row g-4">
                        <% recommendedAccessories.forEach(accessory => { %>
                            <div class="col-md-6 col-xl-3">
                                <article class="recommend-card h-100">
                                    <span class="badge rounded-pill bg-primary-subtle text-primary mb-2"><%= accessory.category %></span>
                                    <h5 class="mb-2"><%= accessory.name %></h5>
                                    <p class="small mb-3"><%= accessory.description %></p>
                                    <div class="d-flex justify-content-between align-items-center mt-auto">
                                        <strong>Rs <%= accessory.price %></strong>
                                        <button
                                            class="btn btn-primary btn-sm"
                                            type="button"
                                            data-add-to-cart
                                            data-id="<%= accessory._id %>"
                                            data-name="<%= accessory.name %>"
                                            data-price="<%= accessory.price %>"
                                            data-image="<%= accessory.image || '' %>"
                                            data-category="<%= accessory.category %>"
                                        >
                                            Add
                                        </button>
                                    </div>
                                </article>
                            </div>
                        <% }) %>
                    </div>
                </section>
            <% } %>

            <section>
                <div class="section-heading d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
                    <div>
                        <p class="eyebrow">Car Accessories</p>
                        <h2 class="display-6 fw-semibold mb-0">Browse available products</h2>
                    </div>
                    <p class="mb-0"><%= accessories.length %> product(s) found</p>
                </div>

                <% if (accessories && accessories.length) { %>
                    <div class="row g-4">
                        <% accessories.forEach(accessory => { %>
                            <div class="col-md-6 col-lg-4">
                                <article class="car-card accessory-card h-100">
                                    <div class="car-photo accessory-photo" style="background-image:url('<%= accessory.image || "https://images.unsplash.com/photo-1485291571150-772bcfc10da5?auto=format&fit=crop&w=1200&q=80" %>')"></div>
                                    <div class="car-card-body d-flex flex-column gap-2">
                                        <div class="d-flex justify-content-between align-items-start gap-3">
                                            <div>
                                                <span class="spec-pill mb-2"><%= accessory.category %></span>
                                                <h5 class="mb-0"><%= accessory.name %></h5>
                                            </div>
                                            <span class="badge rounded-pill bg-primary-subtle text-primary">Rs <%= accessory.price %></span>
                                        </div>
                                        <p class="small mb-3"><%= accessory.description %></p>
                                        <% if (accessory.tags && accessory.tags.length) { %>
                                            <div class="d-flex flex-wrap gap-2 mb-3">
                                                <% accessory.tags.forEach(tag => { %>
                                                    <span class="accessory-tag"><%= tag %></span>
                                                <% }) %>
                                            </div>
                                        <% } %>
                                        <button
                                            class="btn btn-primary mt-auto"
                                            type="button"
                                            data-add-to-cart
                                            data-id="<%= accessory._id %>"
                                            data-name="<%= accessory.name %>"
                                            data-price="<%= accessory.price %>"
                                            data-image="<%= accessory.image || '' %>"
                                            data-category="<%= accessory.category %>"
                                        >
                                            Add to Cart
                                        </button>
                                    </div>
                                </article>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="car-card p-4 text-center">
                        <h5 class="mb-2">No accessories found</h5>
                        <p class="mb-3">Try removing filters or increasing the price range.</p>
                        <a href="/shop" class="btn btn-outline-light">Show All Accessories</a>
                    </div>
                <% } %>
            </section>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>
