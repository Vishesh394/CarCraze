<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Forgot Password | CarCraze</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-surface">
  <%- include("../partials/navbar") %>

  <main class="section auth-shell">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-7 col-xl-6">
          <section class="auth-panel auth-panel--compact">
            <div class="auth-copy">
              <p class="eyebrow mb-3">Password help</p>
              <h1 class="auth-title auth-title--compact">Reset your customer access.</h1>
              <p class="auth-subtitle mb-0">
                Enter the email linked to your account and we will verify it for the next step.
              </p>
            </div>

            <div class="auth-form-wrap">
              <% if (error) { %>
                <div class="alert alert-danger auth-alert" role="alert"><%= error %></div>
              <% } %>

              <% if (success) { %>
                <div class="alert alert-success auth-alert auth-alert-success" role="alert"><%= success %></div>
              <% } %>

              <form action="/forgot-password" method="post" class="d-grid auth-form" autocomplete="off">
                <div>
                  <label class="form-label auth-label">Email Address</label>
                  <input
                    type="email"
                    name="email"
                    class="form-control auth-input"
                    value="<%= formData.email || '' %>"
                    required
                  />
                </div>

                <button type="submit" class="btn btn-primary auth-submit">Continue</button>
              </form>

              <div class="mt-4">
                <a href="/login" class="auth-link">Back to sign in</a>
              </div>
            </div>
          </section>
        </div>
      </div>
    </div>
  </main>

  <%- include("../partials/footer") %>
</body>
</html>
