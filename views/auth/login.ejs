<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Login | CarCraze</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-surface">
  <%- include("../partials/navbar") %>

  <main class="section auth-shell">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
          <section class="auth-panel">
            <div class="auth-copy">
              <p class="eyebrow mb-3">Customer access</p>
              <h1 class="auth-title">Sign in to continue exploring CarCraze.</h1>
              <p class="auth-subtitle mb-0">
                Log in to explore services, book appointments, and browse accessories with a smoother experience.
              </p>
            </div>

            <div class="auth-form-wrap">
              <% if (error) { %>
                <div class="alert alert-danger auth-alert" role="alert"><%= error %></div>
              <% } %>

              <form action="/login" method="post" class="d-grid auth-form" autocomplete="off">
                <input type="hidden" name="nextPath" value="<%= nextPath %>" />

                <div>
                  <label class="form-label auth-label">Email Address</label>
                  <input
                    type="email"
                    name="email"
                    class="form-control auth-input"
                    value="<%= formData.email || '' %>"
                    required
                  />
                </div>

                <div>
                  <label class="form-label auth-label">Password</label>
                  <input type="password" name="password" class="form-control auth-input" autocomplete="current-password" required />
                </div>

                <div class="auth-form-meta">
                  <div class="form-check m-0">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      value="true"
                      id="rememberMe"
                      name="rememberMe"
                      <%= formData.rememberMe ? "checked" : "" %>
                    />
                    <label class="form-check-label auth-meta-text" for="rememberMe">Remember me</label>
                  </div>
                  <a href="/forgot-password" class="auth-link">Forgot password?</a>
                </div>

                <button type="submit" class="btn btn-primary auth-submit">Sign In</button>
              </form>

              <p class="small mt-4 mb-0">
                New here?
                <a href="/signup<%= nextPath && nextPath !== '/' ? '?next=' + encodeURIComponent(nextPath) : '' %>">Create your account</a>
              </p>
            </div>
          </section>
        </div>
      </div>
    </div>
  </main>

  <%- include("../partials/footer") %>
</body>
</html>
