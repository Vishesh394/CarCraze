<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Services | Admin</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-surface">
  <%- include("../partials/navbar") %>

  <main class="section">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
          <p class="eyebrow text-secondary mb-1">Admin</p>
          <h1 class="h3 fw-semibold text-dark mb-0">Service Listings</h1>
          <p class="text-secondary small mb-0">Review all services currently added to CarBarn.</p>
        </div>
        <a class="btn btn-primary" href="/admin/services/add">Add New Service</a>
      </div>

      <% if (services && services.length) { %>
        <div class="row g-4">
          <% services.forEach(service => { %>
            <div class="col-md-6 col-lg-4">
              <article class="car-card h-100">
                <div class="car-photo" style="height:160px; background-image:url('<%= service.image || '' %>');"></div>
                <div class="car-card-body d-flex flex-column gap-2">
                  <div class="d-flex justify-content-between align-items-start gap-3">
                    <h5 class="mb-0"><%= service.title %></h5>
                    <span class="badge rounded-pill bg-primary-subtle text-primary">Rs <%= service.priceMin ?? service.price %> - <%= service.priceMax ?? service.price %></span>
                  </div>

                  <% if (service.description) { %>
                    <p class="small text-secondary mb-0"><%= service.description %></p>
                  <% } %>

                  <p class="text-muted small mb-0">Added <%= service.createdAt.toDateString() %></p>

                  <div class="d-flex gap-2 pt-2 mt-auto flex-wrap">
                    <a href="/admin/services/<%= service._id %>/edit" class="btn btn-outline-primary btn-sm">Edit Service</a>
                    <form action="/admin/services/<%= service._id %>/delete" method="POST" class="m-0" onsubmit="return confirm('Delete <%= service.title %>?')">
                      <button type="submit" class="btn btn-outline-danger btn-sm">Delete Service</button>
                    </form>
                  </div>
                </div>
              </article>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="car-card p-4">
          <p class="text-secondary mb-0">No services have been added yet. Create your first service to get started.</p>
        </div>
      <% } %>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
