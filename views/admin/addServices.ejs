<!-- for adding the services using form by admin -->

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="/css/bootstrap.min.css">
<link rel="stylesheet" href="/css/styles.css">
<title>Add Service | Admin</title>
</head>
<body>
    <div class="bg-surface">
        <div class="container section">
            <div class="car-card p-4">
                <h2 class="mb-3">Create a New Service</h2>
                <% if (typeof error !== "undefined" && error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                <form action="/admin/services" method="POST" class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small text-secondary">Service Name</label>
                        <input type="text" name="title" placeholder="For example: Premium Interior Detail" value="<%= formData?.title || '' %>" required class="form-control">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-secondary">Min Price</label>
                        <input type="number" step="0.01" min="0" name="priceMin" placeholder="499" value="<%= formData?.priceMin || '' %>" required class="form-control">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-secondary">Max Price</label>
                        <input type="number" step="0.01" min="0" name="priceMax" placeholder="999" value="<%= formData?.priceMax || '' %>" required class="form-control">
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-secondary">Image URL (optional)</label>
                        <input type="text" name="image" placeholder="https://example.com/service.jpg" value="<%= formData?.image || '' %>" class="form-control">
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-secondary">Description (optional)</label>
                        <textarea name="description" rows="3" class="form-control" placeholder="Briefly describe what the service includes"><%= formData?.description || '' %></textarea>
                    </div>
                    <div class="col-12 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Service</button>
                        <a href="/admin/dashboard" class="btn btn-outline-secondary">Back to Dashboard</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
<script src="/js/bootstrap.bundle.min.js"></script>
</html>
