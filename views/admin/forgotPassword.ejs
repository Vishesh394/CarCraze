<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Forgot Password | CarCraze Service</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-surface">
  <%- include("../partials/navbar") %>

  <main class="section auth-shell">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-7 col-xl-6">
          <section class="auth-panel auth-panel--compact">
            <div class="auth-copy">
              <p class="eyebrow mb-3">Password help</p>
              <h1 class="auth-title auth-title--compact">Reset your admin access.</h1>
              <p class="auth-subtitle mb-0">
                Enter the email linked to your admin account and we will verify it.
              </p>
            </div>

            <div class="auth-form-wrap">
              <% if (typeof error !== "undefined" && error) { %>
                <div class="alert alert-danger auth-alert" role="alert">
                  <%= error %>
                </div>
              <% } %>

              <% if (typeof success !== "undefined" && success) { %>
                <div class="alert alert-success auth-alert auth-alert-success" role="alert">
                  <%= success %>
                </div>
              <% } %>

              <form action="/admin/forgot-password" method="post" class="d-grid auth-form" autocomplete="off">
                <div>
                  <label class="form-label auth-label">Admin Email</label>
                  <input
                    name="email"
                    type="email"
                    class="form-control auth-input"
                    value="<%= formData?.email || '' %>"
                    autocomplete="off"
                    required
                  />
                </div>

                <button type="submit" class="btn btn-primary auth-submit">Continue</button>
              </form>

              <div class="mt-4">
                <a href="/admin/login" class="auth-link">Back to sign in</a>
              </div>
            </div>
          </section>
        </div>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
