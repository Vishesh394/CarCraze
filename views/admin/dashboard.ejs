<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Admin Dashboard | CarBarn Service</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-surface">
  <%- include("../partials/navbar") %>

  <main class="section">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
          <p class="eyebrow text-secondary mb-1">Admin</p>
          <h1 class="h3 fw-semibold text-white mb-0">Dashboard</h1>
          <p class="text-secondary small mb-0">Manage service listings and keep your dashboard up to date.</p>
        </div>
        <form action="/admin/logout" method="post">
          <button class="btn btn-outline-light">Sign Out</button>
        </form>
      </div>

      <div class="row g-4">
        <div class="col-md-6">
          <article class="car-card h-100">
            <div class="car-photo car-photo-1"></div>
            <div class="car-card-body d-flex flex-column gap-2">
              <h5 class="mb-1">Create a Service</h5>
              <p class="text-secondary small mb-2">Add a new service with a title, price, image, and description.</p>
              <a class="btn btn-primary w-100" href="/admin/services/add">Add New Service</a>
            </div>
          </article>
        </div>
        <div class="col-md-6">
          <article class="car-card h-100">
            <div class="car-photo car-photo-2"></div>
            <div class="car-card-body d-flex flex-column gap-2">
              <h5 class="mb-1">Manage Services</h5>
              <p class="text-secondary small mb-2">Review the services you have already published and keep them organized.</p>
              <a class="btn btn-outline-light w-100" href="/admin/services">View Services</a>
            </div>
          </article>
        </div>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
