<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Admin Login | CarCraze Service</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-surface">
  <%- include("../partials/navbar") %>

  <main class="section auth-shell">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
          <section class="auth-panel">
            <div class="auth-copy">
              <p class="eyebrow mb-3">Admin access</p>
              <h1 class="auth-title">Sign in to continue managing CarCraze.</h1>
              <p class="auth-subtitle mb-0">
                Log in to manage services, track bookings, and update accessories from the dashboard.
              </p>
            </div>

            <div class="auth-form-wrap">
              <% if (typeof error !== "undefined" && error) { %>
                <div class="alert alert-danger auth-alert" role="alert">
                  <%= error %>
                </div>
              <% } %>

              <form action="/admin/login" method="post" class="d-grid auth-form" autocomplete="off">
                <div>
                  <label class="form-label auth-label">Email Address</label>
                  <input
                    name="email"
                    type="email"
                    class="form-control auth-input"
                    value="<%= formData?.email || '' %>"
                    autocomplete="off"
                    required
                  />
                </div>

                <div>
                  <label class="form-label auth-label">Password</label>
                  <input
                    name="password"
                    type="password"
                    class="form-control auth-input"
                    autocomplete="current-password"
                    required
                  />
                </div>

                <div class="auth-form-meta">
                  <div class="form-check m-0">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      value="true"
                      id="rememberMe"
                      name="rememberMe"
                      <%= formData?.rememberMe ? "checked" : "" %>
                    />
                    <label class="form-check-label auth-meta-text" for="rememberMe">Remember me</label>
                  </div>
                  <a href="/admin/forgot-password" class="auth-link">Forgot password?</a>
                </div>

                <button type="submit" class="btn btn-primary auth-submit">Sign In</button>
              </form>
            </div>
          </section>
        </div>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
