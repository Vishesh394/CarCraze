<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Bookings | Admin</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-surface">
  <%- include("../partials/navbar") %>

  <main class="section">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
          <p class="eyebrow text-secondary mb-1">Admin</p>
          <h1 class="h3 fw-semibold text-dark mb-0">Customer Bookings</h1>
          <p class="text-secondary small mb-0">Review all service requests placed by customers.</p>
        </div>
        <a class="btn btn-outline-light" href="/admin/dashboard">Back to Dashboard</a>
      </div>

      <% if (bookings && bookings.length) { %>
        <div class="row g-4">
          <% bookings.forEach(booking => { %>
            <div class="col-md-6 col-xl-4">
              <article class="car-card h-100">
                <div class="car-card-body d-flex flex-column gap-3">
                  <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                      <h5 class="mb-1"><%= booking.serviceTitle %></h5>
                      <p class="small text-secondary mb-0">Booking ID: <%= booking._id %></p>
                    </div>
                    <span class="badge rounded-pill bg-primary-subtle text-primary text-capitalize"><%= booking.status %></span>
                  </div>

                  <div class="booking-note">
                    <p class="mb-1"><strong>Customer:</strong> <%= booking.customerName %></p>
                    <p class="mb-1"><strong>Phone:</strong> <%= booking.phone %></p>
                    <p class="mb-1"><strong>Vehicle:</strong> <%= booking.vehicleModel %></p>
                    <p class="mb-1"><strong>Date:</strong> <%= new Date(booking.bookingDate).toDateString() %></p>
                    <p class="mb-1"><strong>User Email:</strong> <%= booking.user?.email || "Not available" %></p>
                    <p class="mb-0"><strong>Requested:</strong> <%= booking.createdAt.toDateString() %></p>
                  </div>

                  <% if (booking.notes) { %>
                    <div>
                      <p class="small text-secondary mb-1">Notes</p>
                      <p class="small mb-0"><%= booking.notes %></p>
                    </div>
                  <% } %>

                  <% if (booking.service) { %>
                    <div class="mt-auto">
                      <p class="small text-secondary mb-1">Linked Service</p>
                      <p class="small mb-0">
                        <%= booking.service.title %>
                        <% if (booking.service.priceMin || booking.service.price) { %>
                          | Rs <%= booking.service.priceMin ?? booking.service.price %> - <%= booking.service.priceMax ?? booking.service.price %>
                        <% } %>
                      </p>
                    </div>
                  <% } %>
                </div>
              </article>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="car-card p-4">
          <p class="text-secondary mb-0">No customer bookings have been submitted yet.</p>
        </div>
      <% } %>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
