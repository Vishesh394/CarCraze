<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Edit Accessory | Admin</title>
</head>
<body class="bg-surface">
    <main class="section">
        <div class="container">
            <div class="car-card p-4">
                <p class="eyebrow mb-1">Admin</p>
                <h2 class="mb-3">Edit Shop Product</h2>
                <% if (typeof error !== "undefined" && error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                <form action="/admin/accessories/<%= accessory._id %>/edit" method="POST" class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small text-secondary">Product Name</label>
                        <input type="text" name="name" value="<%= accessory.name || '' %>" required class="form-control">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-secondary">Category</label>
                        <select name="category" required class="form-select">
                            <% categories.forEach(category => { %>
                                <option value="<%= category %>" <%= accessory.category === category ? "selected" : "" %>><%= category %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-secondary">Price</label>
                        <input type="number" step="0.01" min="0" name="price" value="<%= accessory.price %>" required class="form-control">
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-secondary">Image URL (optional)</label>
                        <input type="text" name="image" value="<%= accessory.image || '' %>" class="form-control">
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-secondary">Description</label>
                        <textarea name="description" rows="3" required class="form-control"><%= accessory.description || '' %></textarea>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label small text-secondary">Tags (comma separated)</label>
                        <input
                            type="text"
                            name="tags"
                            value="<%= Array.isArray(accessory.tags) ? accessory.tags.join(', ') : accessory.tags || '' %>"
                            class="form-control"
                        >
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="isRecommended" id="isRecommended" <%= accessory.isRecommended ? "checked" : "" %>>
                            <label class="form-check-label" for="isRecommended">Recommended product</label>
                        </div>
                    </div>
                    <div class="col-12 d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn btn-primary">Update Product</button>
                        <a href="/admin/accessories" class="btn btn-outline-secondary">Back to Products</a>
                    </div>
                </form>
            </div>
        </div>
    </main>
    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>
