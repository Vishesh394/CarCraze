<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Service History | Admin</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-surface">
  <%- include("../partials/navbar") %>

  <main class="section">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
          <p class="eyebrow text-secondary mb-1">Admin</p>
          <h1 class="h3 fw-semibold text-dark mb-0">Service History</h1>
          <p class="text-secondary small mb-0">Review completed bookings and past customer service records.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-outline-light" href="/admin/bookings">Active Bookings</a>
          <a class="btn btn-outline-light" href="/admin/dashboard">Back to Dashboard</a>
        </div>
      </div>

      <% if (bookings && bookings.length) { %>
        <div class="row g-4">
          <% bookings.forEach(booking => { %>
            <div class="col-md-6 col-xl-4">
              <article class="car-card h-100">
                <div class="car-card-body d-flex flex-column gap-3">
                  <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                      <h5 class="mb-1"><%= booking.serviceTitle %></h5>
                      <p class="small text-secondary mb-0">Service Date: <%= new Date(booking.bookingDate).toDateString() %></p>
                    </div>
                    <span class="badge rounded-pill bg-success-subtle text-success text-capitalize">Fulfilled</span>
                  </div>

                  <div class="booking-note">
                    <p class="mb-1"><strong>Customer:</strong> <%= booking.customerName %></p>
                    <p class="mb-1"><strong>Phone:</strong> <%= booking.phone %></p>
                    <p class="mb-0"><strong>Vehicle:</strong> <%= booking.vehicleModel %></p>
                  </div>

                  <button
                    class="btn btn-outline-light w-100 mt-auto"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#historyDetails-<%= booking._id %>"
                    aria-expanded="false"
                    aria-controls="historyDetails-<%= booking._id %>"
                  >
                    View Additional Details
                  </button>

                  <div class="collapse" id="historyDetails-<%= booking._id %>">
                    <div class="booking-extra">
                      <p class="mb-1"><strong>Booking ID:</strong> <%= booking._id %></p>
                      <p class="mb-1"><strong>User Email:</strong> <%= booking.user?.email || "Not available" %></p>
                      <p class="mb-1"><strong>Requested:</strong> <%= booking.createdAt.toDateString() %></p>
                      <p class="mb-0"><strong>Fulfilled:</strong> <%= new Date(booking.completedAt || booking.updatedAt).toDateString() %></p>

                      <% if (booking.notes) { %>
                        <div class="pt-3">
                          <p class="small text-secondary mb-1">Notes</p>
                          <p class="small mb-0"><%= booking.notes %></p>
                        </div>
                      <% } %>

                      <% if (booking.service) { %>
                        <div class="pt-3">
                          <p class="small text-secondary mb-1">Linked Service</p>
                          <p class="small mb-0">
                            <%= booking.service.title %>
                            <% if (booking.service.priceMin || booking.service.price) { %>
                              | Rs <%= booking.service.priceMin ?? booking.service.price %> - <%= booking.service.priceMax ?? booking.service.price %>
                            <% } %>
                          </p>
                        </div>
                      <% } %>
                    </div>
                  </div>
                </div>
              </article>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="car-card p-4">
          <p class="text-secondary mb-0">No completed services have been recorded yet.</p>
        </div>
      <% } %>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
